---
import FeatureCard from '../FeatureCard.astro';

const features = [
  {
    title: 'WhatsApp Business API',
    description: 'Akses resmi WhatsApp API dengan fitur lengkap.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.966-.273-.1-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M20.52 3.449C12.831-3.984-.043 1.436.004 12.063c0 2.124.554 4.198 1.6 6.032L0 24l6.068-1.583c8.075 4.354 17.85-1.418 17.89-10.363 0-3.198-1.245-6.206-3.538-8.505zM12.024 21.785a9.81 9.81 0 01-5.02-1.372l-.361-.211-3.596.943.952-3.518-.235-.366a9.814 9.814 0 013.213-13.523c4.55-3.13 10.808-1.938 13.929 2.67 3.144 4.625 1.932 10.906-2.686 14.026a9.772 9.772 0 01-6.196 2.351z"/></svg>`,
  },
  {
    title: 'Instagram DM Integration',
    description: 'Kelola semua DM Instagram dari dashboard yang sama.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  },
  {
    title: 'FB Messenger Integration',
    description: 'Terima dan balas pesan Facebook Messenger langsung. Semua channel Meta dalam satu tempat.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.145 2 11.259c0 2.913 1.454 5.512 3.726 7.21V22l3.405-1.869c.908.252 1.87.388 2.869.388 5.523 0 10-4.144 10-9.26C22 6.145 17.523 2 12 2zm1.008 12.469l-2.546-2.714-4.97 2.714 5.466-5.8 2.609 2.714 4.906-2.714-5.465 5.8z"/></svg>`,
  },
  {
    title: 'Chat Assignment',
    description: 'Assign chat ke agent yang tepat. Kelola workload tim secara efisien.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
  {
    title: 'AI Assistant',
    description: 'Chatbot AI yang cerdas untuk auto-reply dan menjawab pertanyaan 24/7.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><circle cx="8.5" cy="13.5" r="1"/><circle cx="15.5" cy="13.5" r="1"/><path d="M9 17h6"/></svg>`,
  },
  {
    title: 'Team Collaboration',
    description: 'Internal notes, transfer chat — kolaborasi tim jadi seamless.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  },
  {
    title: 'n8n Integration',
    description: 'Workflow automation yang powerful.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="6" cy="6" r="3"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="18" r="3"/><path d="M9 6h6M6 9v6M18 9v6M9 18h6"/></svg>`,
  },
];
---

<section id="tech-provider" class="relative py-20 md:py-32 bg-gradient-to-b from-white via-slate-50/60 to-white overflow-hidden">
  <div class="container-mx">
    <div class="mx-auto max-w-3xl text-center reveal">
      <div class="inline-flex items-center gap-2 rounded-full border border-brand-200 bg-brand-50 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand-700 mb-4">
        Solusinya
      </div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight text-slate-900 leading-[1.15]">
        Solusinya? <span class="text-gradient">mengirim.id</span>.
      </h2>
      <p class="mt-5 text-base md:text-lg text-slate-600 leading-relaxed">
        Platform omnichannel CRM yang bikin tim CS kamu balas chat 24/7, pangkas biaya operasional, dan gak kehilangan satu lead pun dari iklan.
      </p>
    </div>

    <div class="reveal mt-12 md:mt-16">
      <div class="relative mx-auto max-w-5xl">
        <div class="absolute -inset-4 md:-inset-8 rounded-3xl bg-brand-gradient opacity-10 blur-2xl"></div>
        <div class="relative rounded-2xl border border-slate-200 bg-white p-2 shadow-glow">
          <div class="rounded-xl overflow-hidden bg-slate-50">
            <img
              src="/images/dashboard-mockup.png"
              alt="Preview dashboard mengirim.id — satu tempat untuk WhatsApp, Instagram, dan Messenger"
              class="w-full h-auto block"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>

    <p class="reveal mx-auto mt-10 max-w-2xl text-center text-base md:text-lg text-slate-700">
      Mulai dari <span class="font-bold text-brand-700">Rp25 ribu/bulan</span> — setara sekali ngiklan yang gagal convert. Hasilnya? Tim CS kamu makin produktif, tiap chat jadi peluang.
    </p>

    <div class="mt-14 md:mt-20 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      {features.map((f) => <FeatureCard title={f.title} description={f.description} icon={f.icon} />)}
    </div>
  </div>
</section>
