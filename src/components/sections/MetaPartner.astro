---
const highlights = [
  {
    title: 'Akses API Resmi',
    description: 'WhatsApp Business API, Instagram Graph API, dan Messenger API — semua via jalur resmi Meta, bukan reverse-engineered.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>`,
  },
  {
    title: 'Template Pre-Approved',
    description: 'Template pesan disetujui langsung Meta. Deliverability tinggi, compliance otomatis.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>`,
  },
  {
    title: 'Green Tick Verified',
    description: 'Bantu bisnis kamu dapatkan centang hijau resmi WhatsApp Business — kredibilitas langsung naik.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9 12l2 2 4-4"/></svg>`,
  },
  {
    title: 'Support Langsung',
    description: 'Akses jalur escalation ke Meta untuk isu kritis — gak cuma tiket biasa.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>`,
  },
];
---

<section class="relative py-20 md:py-28 bg-slate-50 overflow-hidden">
  <div class="absolute inset-0 -z-10 pointer-events-none opacity-60">
    <div class="absolute top-0 left-1/4 h-64 w-64 rounded-full bg-blue-200/40 blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 h-64 w-64 rounded-full bg-brand-200/40 blur-3xl"></div>
  </div>

  <div class="container-mx">
    <div class="mx-auto max-w-6xl">
      <div class="reveal text-center mb-14">
        <div class="inline-flex items-center gap-2 rounded-full border border-blue-200 bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-blue-700 mb-5">
          Official Partner
        </div>

        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight text-slate-900 leading-[1.15] max-w-3xl mx-auto">
          Kami adalah <span class="bg-gradient-to-r from-[#0064E0] to-[#0082FB] bg-clip-text text-transparent">Meta Business Partner</span> resmi
        </h2>

        <p class="mt-5 text-base md:text-lg text-slate-600 leading-relaxed max-w-2xl mx-auto">
          mengirim.id adalah authorized partner Meta untuk WhatsApp, Instagram, dan Facebook Messenger. Kamu dapat akses langsung ke fitur terbaru, dukungan resmi, dan jaminan compliance — bukan solusi abu-abu yang berisiko banned.
        </p>

        <div class="mt-10 flex justify-center">
          <div class="relative inline-flex">
            <div class="absolute -inset-6 rounded-3xl bg-gradient-to-r from-[#0064E0]/20 via-[#0082FB]/20 to-[#0064E0]/20 blur-2xl"></div>
            <div class="relative rounded-2xl border border-slate-200 bg-white px-10 py-8 shadow-xl">
              <img
                src="/images/meta-business-partner.png"
                alt="Meta Business Partner — Authorized Partner"
                class="h-20 md:h-24 w-auto"
                width="786"
                height="267"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
        </div>
      </div>

      <div class="reveal grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-14">
        {
          highlights.map((h) => (
            <div class="card">
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-blue-50 text-blue-600 mb-3">
                <Fragment set:html={h.icon} />
              </span>
              <h3 class="text-base font-bold text-slate-900 mb-1.5">{h.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed">{h.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
