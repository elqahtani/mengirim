---
import Button from '../Button.astro';
---

<section id="cta" class="relative py-20 md:py-32 overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-brand-gradient"></div>
  <div class="absolute inset-0 -z-10 opacity-[0.15]" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
      <defs>
        <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
  </div>

  <div class="container-mx relative">
    <div class="reveal mx-auto max-w-3xl text-center">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight text-white leading-[1.15]">
        Siap Tingkatkan Customer Experience?
      </h2>
      <p class="mt-5 text-base md:text-lg text-white/90 leading-relaxed">
        Gabung dengan mengirim.id untuk memudahkan CS kelola pesan WhatsApp dan Instagram.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-3">
        <Button
          href="https://app.mengirim.id"
          variant="secondary"
          size="lg"
          class="!bg-white !text-brand-700 hover:!brightness-95 shadow-xl"
        >
          Mulai Gratis Sekarang
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" />
          </svg>
        </Button>
      </div>

      <p class="mt-5 text-sm text-white/80">
        Coba gratis sekarang. Gak perlu kartu kredit. Setup dalam 5 menit. <span aria-hidden="true">🚀</span>
      </p>
    </div>
  </div>
</section>
