---
import Section from '../Section.astro';
import Button from '../Button.astro';

const features = [
  { title: 'Unified Inbox', description: 'Satu inbox untuk semua channel — WhatsApp, Instagram, Messenger. Gak ada lagi bolak-balik tab.' },
  { title: 'Multi-Agent Support', description: 'Tambahkan banyak agent, bagi tugas, dan kelola workload tim dari satu tempat.' },
  { title: 'AI Chatbot', description: 'Auto-reply cerdas 24/7. Jawab FAQ, kualifikasi lead, teruskan ke agent kalau perlu.' },
  { title: 'Broadcast & Bulk Message', description: 'Kirim pesan massal ke kontak tersegmentasi dengan tracking lengkap.' },
  { title: 'CRM & Contact Management', description: 'Kelola kontak, tag, dan segmentasi. Riwayat interaksi lengkap di satu kartu pelanggan.' },
  { title: 'API & Webhook', description: 'Integrasi ke sistem internal kamu via REST API dan webhook real-time.' },
  { title: 'Message Templates', description: 'Template WhatsApp pre-approved untuk notifikasi, promosi, dan transaksi.' },
  { title: 'Reply Buttons', description: 'Tombol balasan cepat untuk mempercepat alur percakapan dan konversi.' },
  { title: 'Interactive List Messages', description: 'Kirim list interaktif untuk menu, katalog, atau pilihan layanan.' },
  { title: 'Media Carousel Messages', description: 'Showcase produk dengan carousel kaya media — gambar, deskripsi, CTA.' },
];
---

<Section
  id="features"
  eyebrow="Fitur"
  title="Fitur Lengkap untuk Bisnis Kamu 🎁"
  subtitle="Dari inbox terpadu sampai automation — semua kamu butuhkan untuk skala customer conversation."
  background="white"
>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 max-w-6xl mx-auto">
    {
      features.map((f) => (
        <div class="card reveal">
          <div class="flex items-start gap-4">
            <span class="flex-none mt-1 inline-flex h-8 w-8 items-center justify-center rounded-lg bg-brand-50 text-brand-700">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 6L9 17l-5-5" />
              </svg>
            </span>
            <div>
              <h3 class="text-base font-bold text-slate-900 mb-1.5">{f.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed">{f.description}</p>
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <div class="reveal mt-14 text-center">
    <Button href="https://app.mengirim.id" variant="primary" size="lg">
      Coba Gratis Sekarang
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M13 5l7 7-7 7" />
      </svg>
    </Button>
  </div>
</Section>
