---
export interface Props {
  class?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { class: className = '', size = 'md' } = Astro.props;

const sizes = {
  sm: 'text-lg',
  md: 'text-xl',
  lg: 'text-2xl',
};
---

<a href="/" class={`inline-flex items-center gap-0 font-extrabold tracking-tight ${sizes[size]} ${className}`} aria-label="mengirim.id">
  <span class="text-slate-900">mengirim</span>
  <span class="text-gradient">.id</span>
</a>
