---
export interface Props {
  title: string;
  description: string;
  number?: string | number;
}

const { title, description, number } = Astro.props;
---

<div class="card reveal relative overflow-hidden">
  {
    number != null && (
      <span class="absolute right-5 top-4 text-5xl font-extrabold text-brand-100 select-none" aria-hidden="true">
        {String(number).padStart(2, '0')}
      </span>
    )
  }
  <h3 class="relative text-lg font-bold text-slate-900 mb-2 pr-10">{title}</h3>
  <p class="relative text-sm text-slate-600 leading-relaxed">{description}</p>
</div>
