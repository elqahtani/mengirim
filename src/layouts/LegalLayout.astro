---
import BaseLayout from './BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  updated?: string;
}

const { title, description, updated } = Astro.props;
---

<BaseLayout title={`${title} — mengirim.id`} description={description}>
  <Navbar />
  <main id="main" class="bg-white">
    <article class="container-mx py-16 md:py-24 max-w-3xl">
      <header class="mb-10 border-b border-slate-200 pb-8">
        <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-slate-900">{title}</h1>
        {updated && <p class="mt-3 text-sm text-slate-500">Terakhir diperbarui: {updated}</p>}
      </header>
      <div class="prose-mengirim">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style is:global>
  .prose-mengirim {
    color: #334155;
    line-height: 1.75;
  }
  .prose-mengirim h2 {
    color: #0f172a;
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }
  .prose-mengirim h3 {
    color: #0f172a;
    font-size: 1.125rem;
    font-weight: 700;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }
  .prose-mengirim p {
    margin-bottom: 1.1rem;
  }
  .prose-mengirim ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.1rem;
  }
  .prose-mengirim li {
    margin-bottom: 0.4rem;
  }
  .prose-mengirim a {
    color: #4f46e5;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose-mengirim a:hover {
    color: #7c3aed;
  }
  .prose-mengirim strong {
    color: #0f172a;
  }
</style>
